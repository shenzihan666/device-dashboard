# Polling interval in seconds (default: 10)
# POLL_INTERVAL_S=10

# Hours of history to backfill on first start (default: 24)
# BACKFILL_HOURS=24

# Seconds without activity before a device is flagged offline (default: 90)
# OFFLINE_GRACE_S=90

# Async SQLAlchemy database URL (default: sqlite under ./data/events.db)
# DB_URL=sqlite+aiosqlite:///data/events.db

# Logging: INFO, DEBUG, etc.
# LOG_LEVEL=INFO

# console (dev) or json (production / log aggregation)
# LOG_FORMAT=console

# CORS: JSON array of origins, e.g. ["http://localhost:5173"] or ["*"]
# CORS_ORIGINS=["*"]

# Upload retention: days to keep uploaded files (default: 30)
# UPLOAD_RETENTION_DAYS=30

# Per-identity disk quota in GB (default: 5)
# UPLOAD_QUOTA_PER_IDENTITY_GB=5

# Disk usage % at which new uploads are rejected with 507 (default: 85)
# UPLOAD_DISK_WATERMARK_PCT=85

# Disk usage % at which emergency sweep deletes oldest files (default: 95)
# UPLOAD_DISK_EMERGENCY_PCT=95

# File extensions to gzip on ingest (default: [".log", ".jsonl"])
# UPLOAD_COMPRESS_KINDS=[".log", ".jsonl"]

# Enable content-addressable dedup for uploaded blobs (default: true)
# UPLOAD_DEDUP_ENABLED=true

# Retention sweeper interval in minutes (default: 60)
# UPLOAD_SWEEPER_INTERVAL_MIN=60
