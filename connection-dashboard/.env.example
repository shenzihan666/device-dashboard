# Grafana Cloud Service Account token (starts with `glsa_`).
API_TOKEN=glsa_...

# Grafana instance URL (default: https://mynameisi.grafana.net)
# GRAFANA_URL=https://mynameisi.grafana.net

# Loki datasource UID (default: grafanacloud-logs)
# LOKI_DATASOURCE_UID=grafanacloud-logs

# LangSmith API key for trace drill-through (optional)
# LANGSMITH_API_KEY=lsv2_pt_...

# Polling interval in seconds (default: 10)
# POLL_INTERVAL_S=10

# Hours of history to backfill on first start (default: 24)
# BACKFILL_HOURS=24

# Seconds without activity before a device is flagged offline (default: 90)
# OFFLINE_GRACE_S=90
